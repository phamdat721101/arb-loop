# ── Contracts (Arbitrum) ──────────────────────────────────
RPC_URL_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
DEPLOYER_PRIVATE_KEY=
ARBISCAN_API_KEY=

# ── Backend API ────────────────────────────────────────────
DATABASE_URL=postgresql://brain:changeme@localhost:5432/fhe_brain
POSTGRES_PASSWORD=changeme
REDIS_HOST=localhost
REDIS_PORT=6379
OPENAI_API_KEY=
# Set to "off" to force /v3/discover onto the TF-IDF floor strategy even if
# BEDROCK_API_KEY or OPENAI_API_KEY is present. Default = on whenever a
# provider key is configured.
OPENX_DISCOVERY_LLM=on
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
PRIVATE_KEY=
PLATFORM_WALLET=
SUBSCRIPTION_CONTROLLER_ADDRESS=
KNOWLEDGE_REGISTRY_ADDRESS=
BRAIN_KEY_VAULT_ADDRESS=
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org
PORT=3001

# ── Agent (legacy) ────────────────────────────────────────
AGENT_PRIVATE_KEY=
CONTEXT_MANAGER_ADDRESS=
MEMORY_STORE_ADDRESS=
AGENT_REGISTRY_ADDRESS=

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_AGENT_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_SUBSCRIPTION_CONTROLLER_ADDRESS=
NEXT_PUBLIC_KNOWLEDGE_REGISTRY_ADDRESS=
NEXT_PUBLIC_BRAIN_KEY_VAULT_ADDRESS=
NEXT_PUBLIC_CONTEXT_MANAGER_ADDRESS=
NEXT_PUBLIC_MEMORY_STORE_ADDRESS=
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_AGENT_ADDRESS=

# ── Platform signer (server-side) ──────────────────────────
# Used by cognitiveMemoryService to sign platform-relayed memory writes.
# Backward-compat: ARKIV_BACKEND_PRIVATE_KEY is still honored if this is unset.
PLATFORM_SIGNER_PRIVATE_KEY=

# ── Private payment (T4–T7) ───────────────────────────────
# Populated by deploy-fhe-pay.ts; copy from deployments/arbitrum-sepolia.json.
WRAPPED_USDC_ADDRESS=
AGENT_BILLING_ADDRESS=
SETTLEMENT_LEDGER_ADDRESS=
NEXT_PUBLIC_WRAPPED_USDC_ADDRESS=
NEXT_PUBLIC_AGENT_BILLING_ADDRESS=
NEXT_PUBLIC_SETTLEMENT_LEDGER_ADDRESS=

# Feature flags (T5–T7)
# FEATURE_FHE_PAY=true enables /v4 routes, freemium gate, and the one-tap UI.
# FEATURE_FHE_PAY=false (default) preserves byte-identical v2 behaviour.
FEATURE_FHE_PAY=false
# Free-preview limit per (wallet × brain). Set to 0 to disable freemium entirely.
FREE_PREVIEW_LIMIT=5

# Feature flag — PRD-19 gasless non-crypto seller onboarding (Arbitrum Sepolia).
# When true, the publish path enqueues a chain_ops_queue row and the worker's
# chain-relayer drains it (signs createBrain() with RELAYER_PRIVATE_KEY).
# When false (default), publish stays DB-only — byte-identical to PRD-18.
FEATURE_GASLESS_ONBOARD=false
# Relayer wallet — pre-funded EOA that signs gasless on-chain ops. Defaults
# to DEPLOYER_PRIVATE_KEY when unset. Fund with ≥0.005 ETH on Arbitrum
# Sepolia (~1000 onboards). Slack alert fires once/hour via
# SLACK_ALERTS_WEBHOOK when balance drops below 0.005.
RELAYER_PRIVATE_KEY=
# Optional: webhook for low-balance + future ops alerts. Empty → no alerts.
SLACK_ALERTS_WEBHOOK=
# Worker poll interval (ms). Default 5000 — single hot wallet, low cadence.
RELAYER_POLL_MS=5000

# ── Hosted MCP gateway ────────────────────────────────────
# Phase 1 = HTTP at api.openx.so/mcp.
OPENX_MCP_PUBLIC_URL=https://api.openx.so/mcp
# Buyer-side OpenX API key for `@openx/mcp` clients.
OPENX_API_KEY=

# ── Marketplace v1 (PRD-A/B/C — seller-first onboarding) ──
# Off by default. When 'true', the /seller/onboard wizard is reachable
# from the AppShell nav. Routes under /v3/marketplace/* are always
# mounted; the flag only gates the UI surface. Migration 023 must be
# applied before flipping this on.
FEATURE_MARKETPLACE_V1=false
# Seller-first onboarding v2 (PRD-14/15/16) — 5-step wizard with seller↔agent
# split. When false, the publish endpoint accepts the v1 payload byte-identically.
FEATURE_MARKETPLACE_V1_SELLER_FIRST=false

# PRD-18 — Permit-authenticated one-prompt onboarding.
# When 'false' (default), POST /v3/marketplace/seller/publish accepts BOTH
# x-wallet-address (legacy) and x-fhenix-permit (new). When 'true', only
# the scoped onboard permit minted at /docs is honored.
FEATURE_PERMIT_AUTH=false

# ── arb-loop v0.0 simple (Arbitrum + Fhenix + x402/Permit2) ─────
# Master flag — set to 'false' to disable the entire /v3/arbloop router
# (byte-identical heavy-v0.1 fallback). Default ON in v0.0 ship.
FEATURE_ARBLOOP=true
# Bundle sub-flags per docs/runbooks/ARBLOOP_FLAGS.md (default ON in code; set
# to 'false' explicitly only if the corresponding contracts/services aren't
# deployed yet, in which case the route fails-soft with descriptive error).
FEATURE_ARBLOOP_CHAT_EXECUTION=true
FEATURE_ARBLOOP_GASLESS_PUBLISH=false
FEATURE_ARBLOOP_X402=false
FEATURE_ARBLOOP_FHE_PIPELINE=false
FEATURE_ARBLOOP_PERMIT2_HIRE=false
# Heavy v0.1 sub-flags (deferred but kept addressable for rollback)
FEATURE_ARBLOOP_PHALA=true
FEATURE_ARBLOOP_AIZEL=false
FEATURE_ARBLOOP_CHECKPOINTS=true
FEATURE_ARBLOOP_MCP=true
FEATURE_ARBLOOP_EIGENDA=true

# Storage runtime mode — 'mock' uses Postgres-backed mock clients (v0.1 default),
# 'real' wires the EigenDA + Arweave (Irys) + Lit Protocol SDKs (v0.2).
RUNTIME_STORAGE_MODE=mock

# Master secret used by MockLitEncryption to derive per-policy AES-256-GCM keys
# via HKDF. Required when RUNTIME_STORAGE_MODE=mock. 32+ bytes random in prod.
ARBLOOP_LIT_MOCK_MASTER_SECRET=

# Deployed contract addresses (populate from deployments/arbitrum-sepolia.json after Phase 1 deploy).
ARBLOOP_AGENT_REGISTRY_ADDRESS=
ARBLOOP_LOOP_JOB_FACTORY_ADDRESS=
ARBLOOP_AGENT_NS_FACTORY_ADDRESS=
ARBLOOP_JOB_NS_FACTORY_ADDRESS=
ARBLOOP_ITERATION_RECEIPT_ADDRESS=
ARBLOOP_CHECKPOINT_APPROVAL_ADDRESS=
ARBLOOP_PULLSPLIT_FACTORY_ADDRESS=

# EAS schemas — pre-registered on Arbitrum Sepolia (Phase 1 task).
ARBLOOP_EAS_CONTRACT_ADDRESS=0xbD75f629A22Dc1ceD33dDA0b68c546A1c035c458
ARBLOOP_ITER_SCHEMA_UID=
ARBLOOP_L5_SCHEMA_UID=

# USDC on Arbitrum Sepolia (Circle official testnet).
ARBLOOP_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Permit2 universal address (same on every EVM chain).
ARBLOOP_PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3

# Multicall3 universal address.
ARBLOOP_MULTICALL3_ADDRESS=0xcA11bde05977b3631167028862bE2a173976CA11

# Phala backend (already wired via chat.ts; reused for arbloop).
# PHALA_ENDPOINT, PHALA_API_KEY, PHALA_MODEL — see Trustless tier block above.
