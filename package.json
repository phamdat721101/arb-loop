{
  "name": "arb-mem",
  "private": true,
  "workspaces": [
    "packages/agent",
    "packages/api",
    "packages/contracts",
    "packages/frontend",
    "packages/openx-mcp",
    "packages/runtime-utils",
    "packages/sdk",
    "packages/shared",
    "packages/ui",
    "packages/worker",
    "packages/zama-contracts"
  ],
  "overrides": {
    "ox": "0.6.7"
  },
  "scripts": {
    "runtime-utils:build": "npm run build -w packages/runtime-utils",
    "sdk:build": "npm run build -w packages/sdk",
    "ui:build": "npm run build -w packages/ui",
    "openx-mcp:build": "npm run build -w packages/openx-mcp",
    "api:dev": "npm run dev -w packages/api",
    "api:build": "npm run build -w packages/api",
    "api:start": "npm run start -w packages/api",
    "contracts:compile": "npx hardhat compile --config packages/contracts/hardhat.config.ts",
    "contracts:deploy": "npx hardhat run packages/contracts/scripts/deploy-brain-system.ts --config packages/contracts/hardhat.config.ts",
    "frontend:dev": "npm run dev -w packages/frontend",
    "frontend:build": "npm run build -w packages/frontend",
    "frontend:start": "npm run start -w packages/frontend",
    "build": "npm run runtime-utils:build && npm run sdk:build && npm run ui:build && npm run openx-mcp:build && npm run api:build",
    "dev": "./scripts/start-dev.sh",
    "docker:up": "docker compose up -d",
    "docker:build": "docker compose build --parallel",
    "deploy": "./scripts/deploy.sh",
    "smoke:auth": "tsx scripts/smoke-auth.ts",
    "smoke:chunks-auth": "tsx scripts/smoke-chunks-auth.ts",
    "smoke:x402": "tsx scripts/smoke-x402.ts",
    "smoke:cognitive-l4-l5": "tsx scripts/smoke-cognitive-l4-l5.ts",
    "smoke:workflow-runner": "tsx scripts/smoke-workflow-runner.ts",
    "smoke:marketing-workflow": "tsx scripts/smoke-marketing-workflow.ts",
    "smoke:marketplace-seller-flow": "tsx scripts/smoke-marketplace-seller-flow.ts",
    "smoke:permit-onboard": "tsx scripts/smoke-marketplace-seller-flow.ts",
    "smoke:marketplace-seller-first": "tsx scripts/smoke-marketplace-seller-first.ts",
    "smoke:fhenix-onboard": "tsx scripts/smoke-fhenix-onboard.ts",
    "smoke:arbloop": "tsx scripts/smoke-arbloop.ts",
    "smoke:arbloop-gasless-publish": "tsx scripts/smoke-arbloop-gasless-publish.ts",
    "smoke:arbloop-x402": "tsx scripts/smoke-arbloop-x402.ts",
    "smoke:arbloop-fhe": "tsx scripts/smoke-arbloop-fhe.ts",
    "smoke:arbloop-permit2-hire": "tsx scripts/smoke-arbloop-permit2-hire.ts",
    "smoke:arbloop-translation": "tsx scripts/smoke-arbloop-translation.ts",
    "smoke:arbloop-responsive": "bash scripts/smoke-arbloop-responsive.sh",
    "seed:translator": "tsx scripts/seed-translator-agent.ts",
    "deploy:arbloop": "npx hardhat run packages/contracts/scripts/deploy-arbloop.ts --config packages/contracts/hardhat.config.ts --network arbitrumSepolia",
    "demo:agentic-market": "tsx scripts/demo-agentic-market.ts",
    "db:migrate": "bash -c 'for f in packages/shared/migrations/*.sql; do psql \"$DATABASE_URL\" -f \"$f\" || true; done'"
  }
}
